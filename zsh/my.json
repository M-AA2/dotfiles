{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "console_title_template": "{{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "style": "diamond",
          "leading_diamond": "",
          "foreground": "#89b4fa",
          "template": " {{.Icon}} "
        },
        {
          "type": "session",
          "style": "diamond",
          "leading_diamond": "<transparent,#b4befe></>",
          "foreground": "#1e1e2e",
          "background": "#b4befe",
          "template": " {{ .UserName }} "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#1e1e2e",
          "background": "#a6e3a1",
          "template": " {{ .Path }} ",
          "properties": {
            "style": "folder"
          }
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "#1e1e2e",
          "background": "#f9e2af",
          "template": " {{ .HEAD }}{{ if .Working.Changed }} {{ .Working.String }}{{ end }}{{ if .Staging.Changed }} {{ .Staging.String }}{{ end }} ",
          "properties": {
            "branch_icon": "",
            "fetch_status": true
          }
        },
        {
          "type": "executiontime",
          "style": "diamond",
          "trailing_diamond": "",
          "foreground": "#cdd6f4",
          "background": "#6c7086",
          "template": " {{ .FormattedMs }} ",
          "properties": {
            "threshold": 500,
            "style": "roundrock"
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "time",
          "style": "diamond",
          "leading_diamond": "",
          "trailing_diamond": "",
          "foreground": "#1e1e2e",
          "background": "#f5c2e7",
          "template": " {{ .CurrentDate | date .Format }} ",
          "properties": {
            "time_format": "15:04:05"
          }
        },
        {
          "type": "battery",
          "style": "diamond",
          "leading_diamond": "<#94e2d5,#f5c2e7></>",
          "trailing_diamond": "",
          "foreground": "#1e1e2e",
          "background": "#94e2d5",
          "template": " {{ .Percentage }}% ",
          "properties": {
            "charged_icon": "",
            "charging_icon": "",
            "discharging_icon": ""
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "exit",
          "style": "plain",
          "foreground": "#a6e3a1",
          "foreground_templates": ["{{ if gt .Code 0 }}#f38ba8{{ end }}"],
          "template": "{{ if gt .Code 0 }}✖{{ else }}❯{{ end }} ",
          "properties": {
            "always_enabled": true
          }
        }
      ]
    }
  ]
}
